# Stripe (required)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Database (required for production)
DATABASE_URL=postgresql://user:pass@host:5432/dispute_defender

# Admin auth — bearer token for /api/disputes/[id]/submit and /api/jobs/process
# In production replace with real auth (Auth0, Clerk, NextAuth, etc.)
ADMIN_TOKEN=replace_with_a_long_random_string
JOB_PROCESSOR_SECRET=replace_with_a_long_random_string

# Ed25519 signing key for evidence manifest (32-byte seed, 64 hex chars)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
DISPUTE_SIGNING_KEY=

# Optional: opt-in to auto-submit (default: human review required)
DD_AUTO_SUBMIT=false

# Public app URL (used in CLI + manifest URLs)
NEXT_PUBLIC_APP_URL=http://localhost:3000
