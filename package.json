{
  "name": "@merchantguard/dispute-defender",
  "version": "0.2.0",
  "private": false,
  "description": "Typed, deterministic helper library for assembling chargeback-evidence payloads in the shape required by Visa Compelling Evidence 3.0 and staging them via the Stripe Disputes API for merchant human review prior to submission. Static templates only, no LLM-generated narrative, audit-logged.",
  "license": "MIT",
  "patents": "https://github.com/MerchantGuard/dispute-defender/blob/main/PATENTS.md",
  "homepage": "https://github.com/MerchantGuard/dispute-defender#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MerchantGuard/dispute-defender.git"
  },
  "bugs": {
    "url": "https://github.com/MerchantGuard/dispute-defender/issues"
  },
  "author": "Dunecrest Ventures Inc.",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "stripe:version": "tsx scripts/stripe-version.ts",
    "jobs:process": "tsx scripts/jobs-process.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "cli:init": "tsx scripts/cli-init.ts",
    "cli:test": "tsx scripts/cli-test.ts"
  },
  "dependencies": {
    "@noble/ed25519": "^2.1.0",
    "drizzle-orm": "^0.36.4",
    "next": "^14.2.0",
    "pdf-lib": "^1.17.1",
    "postgres": "^3.4.5",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "stripe": "^22.1.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "dotenv": "^16.4.5",
    "drizzle-kit": "^0.28.1",
    "eslint": "^8.57.0",
    "eslint-config-next": "^14.2.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0",
    "vitest": "^2.1.0"
  }
}
